APP_NAME="Hema Indonesia"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ===== DATABASE =====
# Default: SQLite (paling cepat untuk lokal).
# Buat file kosong: database/database.sqlite
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=hema_indonesia
# DB_USERNAME=root
# DB_PASSWORD=

# ===== SESSION / CACHE / QUEUE =====
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

# ===== MAIL =====
# 'log' = email ditulis ke storage/logs (tidak benar-benar terkirim).
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@hemaindonesia.test"
MAIL_FROM_NAME="${APP_NAME}"

# ===== MIDTRANS (Payment Gateway) =====
# Ambil key di dashboard Midtrans (mode Sandbox untuk testing).
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_MERCHANT_ID=
MIDTRANS_IS_PRODUCTION=false

VITE_APP_NAME="${APP_NAME}"
